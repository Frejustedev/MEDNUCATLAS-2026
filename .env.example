# ============================================================
# NucleAtlas — Variables d'environnement
# ============================================================
# Ne JAMAIS commiter de fichier .env.local — voir .gitignore
# Les variables NEXT_PUBLIC_* sont exposées au navigateur :
# n'y mettre AUCUN secret.

# --- Gemini (server-side uniquement) ---
# Clé API Gemini. SERVER-ONLY — ne jamais préfixer NEXT_PUBLIC_.
GEMINI_API_KEY="your-gemini-api-key"
GEMINI_MODEL_GENERATE="gemini-2.5-pro"
GEMINI_MODEL_CHAT="gemini-2.5-flash"

# --- Firebase Admin (server-side) ---
# Service account encodé en base64 (cat service-account.json | base64).
# Crée le compte de service depuis la console Firebase >
#   Paramètres du projet > Comptes de service > Générer une nouvelle clé.
FIREBASE_SERVICE_ACCOUNT_B64=""

# Project ID Firebase (doit matcher firebase-applet-config.json).
FIREBASE_PROJECT_ID="gen-lang-client-0346429614"

# ID de la base Firestore (nommée, pas (default)).
FIREBASE_FIRESTORE_DATABASE_ID="ai-studio-77e401c9-98b2-4e02-9088-8a3ea6d17150"

# --- App ---
APP_URL="http://localhost:3000"

# Email de l'administrateur principal pour notifications (optionnel).
ADMIN_NOTIFICATION_EMAIL="contact@nucleatlas.org"

# --- Rate limiting (optionnel — fallback Firestore si vide) ---
# Si renseigné, utilisé via @upstash/ratelimit pour les routes IA.
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# --- reCAPTCHA / App Check (optionnel mais recommandé en prod) ---
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=""
